<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- Arrival banner — floats on top -->
    <TextView
        android:id="@+id/arrivalBanner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:gravity="center"
        android:background="@color/teal"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Routes label -->
    <TextView
        android:id="@+id/tvRoutesLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ROUTES"
        android:textColor="@color/text_dim"
        android:textSize="10sp"
        android:letterSpacing="0.15"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Routes RecyclerView (horizontal) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRoutes"
        android:layout_width="0dp"
        android:layout_height="110dp"
        android:layout_marginTop="4dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:orientation="horizontal"
        tools:listitem="@layout/item_route"
        app:layout_constraintTop_toBottomOf="@id/tvRoutesLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvNoRoutes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Loading routes…"
        android:textColor="@color/text_dim"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/rvRoutes"
        app:layout_constraintBottom_toBottomOf="@id/rvRoutes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Canvas route map -->
    <com.yatrimitra.ui.RouteView
        android:id="@+id/routeView"
        android:layout_width="0dp"
        android:layout_height="170dp"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/rvRoutes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ETA card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/etaCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="6dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="14dp"
        app:strokeColor="@color/border"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/routeView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvEtaLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select a stop"
                    android:textColor="@color/text_dim"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/tvEta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="@color/saffron"
                    android:textSize="34sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="44dp"
                android:background="@color/border"
                android:layout_marginHorizontal="10dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOUR STOP"
                    android:textColor="@color/text_dim"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/tvSelectedStop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="None selected"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="44dp"
                android:background="@color/border"
                android:layout_marginHorizontal="10dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VEHICLES"
                    android:textColor="@color/text_dim"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/tvVehicleCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/green"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Stops label -->
    <TextView
        android:id="@+id/tvStopsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BOARDING STOP"
        android:textColor="@color/text_dim"
        android:textSize="10sp"
        android:letterSpacing="0.15"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/etaCard"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Stops list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvStops"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="4dp"
        tools:listitem="@layout/item_stop"
        app:layout_constraintTop_toBottomOf="@id/tvStopsLabel"
        app:layout_constraintBottom_toTopOf="@id/controlsCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Controls card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/controlsCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="12dp"
        app:strokeColor="@color/border"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/tvStats"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStart"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="▶ Start"
                    app:backgroundTint="@color/saffron" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPause"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:text="⏸ Pause"
                    android:enabled="false"
                    app:backgroundTint="@color/bg3" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddVehicle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="+ Auto"
                    app:backgroundTint="@color/teal" />
            </LinearLayout>

            <!-- Speed slider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Speed"
                    android:textColor="@color/text_dim"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderSpeed"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:valueFrom="10"
                    android:valueTo="60"
                    android:value="30"
                    app:thumbColor="@color/saffron"
                    app:trackColorActive="@color/saffron"
                    app:trackColorInactive="@color/border" />

                <TextView
                    android:id="@+id/tvSpeedVal"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:text="30 km/h"
                    android:textColor="@color/amber"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="end"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Rider registration -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:hint="Your name (optional)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRiderName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:textColor="@color/text" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegister"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Register"
                    app:backgroundTint="@color/purple" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Stats bar — SINGLE id, at bottom -->
    <TextView
        android:id="@+id/tvStats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:gravity="center"
        android:background="@color/bg2"
        android:textColor="@color/text_dim"
        android:textSize="11sp"
        android:text="Routes: 0  ·  Vehicles: 0  ·  Arrivals: 0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
