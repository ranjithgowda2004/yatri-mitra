<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="amber">#FFB300</color>
    <color name="bg">#0D1117</color>
    <color name="bg2">#161B22</color>
    <color name="bg3">#21262D</color>
    <color name="blue">#58A6FF</color>
    <color name="border">#30363D</color>
    <color name="deep_saffron">#E05A00</color>
    <color name="green">#3FB950</color>
    <color name="purple">#7C4DFF</color>
    <color name="red">#F85149</color>
    <color name="saffron">#FF6B00</color>
    <color name="surface">#1C2128</color>
    <color name="teal">#00897B</color>
    <color name="text">#E6EDF3</color>
    <color name="text_dim">#8B949E</color>
    <color name="white">#FFFFFF</color>
    <string name="app_name">Yatri-Mitra</string>
    <style name="Theme.YatriMitra" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/saffron</item>
        <item name="colorPrimaryVariant">@color/deep_saffron</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text</item>
        <item name="android:statusBarColor">@color/bg2</item>
        <item name="android:navigationBarColor">@color/bg2</item>
        <item name="android:textColorPrimary">@color/text</item>
        <item name="android:textColorSecondary">@color/text_dim</item>
    </style>
    <style name="Theme.YatriMitra.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg</item>
        <item name="postSplashScreenTheme">@style/Theme.YatriMitra</item>
    </style>
</resources>